#!/bin/sh
PIDFILE="/run/dropbear.pid"
LOGFILE="/system/sdcard/log/dropbear.log"
DROPBEAR="/system/sdcard/bin/dropbearmulti"
SSH_PORT=22

log() {
  echo "$(date +"%D %T") $@" >> "$LOGFILE"
}

if [ ! -d /system/sdcard/root/.ssh ]; then
  mkdir /system/sdcard/root/.ssh
fi

if [ ! -f /root/.ssh/authorized_keys ]; then 
  touch /root/.ssh/authorized_keys
fi

if [ ! -f /system/sdcard/config/ssh.conf ]; then 
  cp /system/sdcard/config/ssh.conf.dist /system/sdcard/config/ssh.conf
fi

if [ ! -f /system/bin/scp ]; then
  ln -s "$DROPBEAR" /system/bin/scp
fi

if [ ! -f /var/log/lastlog ]; then
  touch /var/log/lastlog 2>/dev/null
fi

if [ -f /system/sdcard/config/ssh.conf ]; then
  . /system/sdcard/config/ssh.conf
fi

if [ -n "$ssh_port" ]; then
  SSH_PORT="$ssh_port"
fi

status()
{
  pid="$(cat "$PIDFILE" 2>/dev/null)"
  if [ "$pid" ]; then
	kill -0 "$pid" >/dev/null && echo "PID: $pid" || return 1
  fi
}

start()
{
  if [ "$(status)" != "" ]; then
	log "Already running (PID: $(cat $PIDFILE))"
	echo "Dropbear already running"
  else
	log "Starting dropbear on port $SSH_PORT (password auth: ${ssh_password:-on})"
	echo "Starting Dropbear on port $SSH_PORT"

	if [ ! -x "$DROPBEAR" ]; then
		log "ERROR: $DROPBEAR not found or not executable"
		echo "ERROR: dropbearmulti not found"
		return 1
	fi

	if [ "$ssh_password" = "off" ]; then
		"$DROPBEAR" dropbear -s -R -p $SSH_PORT >> "$LOGFILE" 2>&1
	else
		"$DROPBEAR" dropbear -R -p $SSH_PORT >> "$LOGFILE" 2>&1
	fi

	DROPBEAR_PID=$!
	sleep 1

	if kill -0 "$DROPBEAR_PID" 2>/dev/null; then
		echo "$DROPBEAR_PID" > "$PIDFILE"
		log "Started successfully (PID: $DROPBEAR_PID)"
		echo "Dropbear started (PID: $DROPBEAR_PID)"
	else
		log "ERROR: Failed to start dropbear (exit: $?)"
		echo "ERROR: Failed to start dropbear, check $LOGFILE"
		return 1
	fi
  fi
}

stop()
{
  pid="$(cat "$PIDFILE" 2>/dev/null)"
  if [ "$pid" ]; then
	log "Stopping (PID: $pid)"
	kill "$pid" 2>/dev/null
	rm "$PIDFILE" 2>/dev/null
  fi
}

if [ $# -eq 0 ]; then
  start
else
  case $1 in start|stop|status)
	$1
	;;
  esac
fi
